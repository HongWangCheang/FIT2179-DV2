{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": {
    "text": "Australian Forest Fire Activity by State/Territory",
    "subtitle": "Choropleth = total fire, circle size = unplanned fire",
    "fontSize": 20,
    "subtitleFontSize": 13,
    "anchor": "middle"
  },

  "width": 725,
  "height": 600,
  "background": "#FAF8F3",

  "params": [
    {
      "name": "selected_year",
      "value": "2019-20",
      "bind": {
        "input": "select",
        "name": "Select year: ",
        "options": ["2016-17", "2017-18", "2018-19", "2019-20", "2020-21"]
      }
    }
  ],

  "projection": {
    "type": "mercator",
    "center": [134, -28],
    "scale": 700
  },

  "layer": [
    {
      "data": {
        "url": "fire_veg_lite_long_state_year_type.csv"
      },
      "transform": [
        {
          "filter": "datum.year == selected_year"
        },
        {
          "pivot": "fire_type",
          "value": "cell_count",
          "groupby": ["state", "year", "latitude", "longitude"],
          "op": "sum"
        },
        {
          "calculate": "(datum['Planned fire'] || 0) + (datum['Unplanned fire'] || 0)",
          "as": "total_fire_cells"
        },
        {
          "calculate": "datum['Unplanned fire'] || 0",
          "as": "unplanned_fire_cells"
        },
        {
          "calculate": "datum['Planned fire'] || 0",
          "as": "planned_fire_cells"
        },
        {
          "calculate": "datum.total_fire_cells > 0 ? datum.unplanned_fire_cells / datum.total_fire_cells * 100 : 0",
          "as": "unplanned_fire_percent"
        },
        {
          "calculate": "datum.state == 'NSW' ? 'New South Wales' : datum.state == 'Vic' ? 'Victoria' : datum.state == 'Qld' ? 'Queensland' : datum.state == 'WA' ? 'Western Australia' : datum.state == 'SA' ? 'South Australia' : datum.state == 'Tas' ? 'Tasmania' : datum.state == 'NT' ? 'Northern Territory' : datum.state == 'ACT' ? 'Australian Capital Territory' : datum.state",
          "as": "state_name"
        },
        {
          "lookup": "state_name",
          "from": {
            "data": {
              "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/master/states.geojson",
              "format": {
                "type": "json",
                "property": "features"
              }
            },
            "key": "properties.STATE_NAME"
          },
          "as": "geo"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 1.2
      },
      "encoding": {
        "shape": {
          "field": "geo",
          "type": "geojson"
        },
        "color": {
          "field": "total_fire_cells",
          "type": "quantitative",
          "title": "Total Fire Count",
          "scale": {
            "scheme": "yelloworangered"
          },
          "legend": {
            "orient": "right",
            "titleFontSize": 12,
            "labelFontSize": 11,
            "format": ",.0f"
          }
        },
        "tooltip": [
          {
            "field": "state_name",
            "type": "nominal",
            "title": "State/Territory"
          },
          {
            "field": "year",
            "type": "nominal",
            "title": "Year"
          },
          {
            "field": "total_fire_cells",
            "type": "quantitative",
            "title": "Total Fire Count",
            "format": ",.0f"
          },
          {
            "field": "planned_fire_cells",
            "type": "quantitative",
            "title": "Planned Fire Count",
            "format": ",.0f"
          },
          {
            "field": "unplanned_fire_cells",
            "type": "quantitative",
            "title": "Unplanned Fire Count",
            "format": ",.0f"
          },
          {
            "field": "unplanned_fire_percent",
            "type": "quantitative",
            "title": "Unplanned Fire %",
            "format": ".1f"
          }
        ]
      }
    },

    {
      "data": {
        "url": "fire_veg_lite_long_state_year_type.csv"
      },
      "transform": [
        {
          "filter": "datum.year == selected_year"
        },
        {
          "pivot": "fire_type",
          "value": "cell_count",
          "groupby": ["state", "year", "latitude", "longitude"],
          "op": "sum"
        },
        {
          "calculate": "(datum['Planned fire'] || 0) + (datum['Unplanned fire'] || 0)",
          "as": "total_fire_cells"
        },
        {
          "calculate": "datum['Unplanned fire'] || 0",
          "as": "unplanned_fire_cells"
        },
        {
          "calculate": "datum['Planned fire'] || 0",
          "as": "planned_fire_cells"
        },
        {
          "calculate": "datum.total_fire_cells > 0 ? datum.unplanned_fire_cells / datum.total_fire_cells * 100 : 0",
          "as": "unplanned_fire_percent"
        },
        {
          "calculate": "datum.latitude - 1.4",
          "as": "circle_latitude"
        }
      ],
      "mark": {
        "type": "circle",
        "opacity": 0.75,
        "color": "#5C5C5C",
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative",
          "title": "Longitude"
        },
        "latitude": {
          "field": "circle_latitude",
          "type": "quantitative",
          "title": "Latitude"
        },
        "size": {
          "field": "unplanned_fire_cells",
          "type": "quantitative",
          "title": "Total Fire",
          "scale": {
            "range": [80, 1800]
          },
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "titleFontSize": 12,
            "labelFontSize": 11,
            "format": ",.0f",
            "tickCount": 5
          }
        },
        "tooltip": [
          {
            "field": "state",
            "type": "nominal",
            "title": "State/Territory"
          },
          {
            "field": "year",
            "type": "nominal",
            "title": "Year"
          },
          {
            "field": "total_fire_cells",
            "type": "quantitative",
            "title": "Total Fire Count",
            "format": ",.0f"
          },
          {
            "field": "planned_fire_cells",
            "type": "quantitative",
            "title": "Planned Fire Count",
            "format": ",.0f"
          },
          {
            "field": "unplanned_fire_cells",
            "type": "quantitative",
            "title": "Unplanned Fire Count",
            "format": ",.0f"
          },
          {
            "field": "unplanned_fire_percent",
            "type": "quantitative",
            "title": "Unplanned Fire %",
            "format": ".1f"
          }
        ]
      }
    },

    {
      "data": {
        "url": "fire_veg_lite_long_state_year_type.csv"
      },
      "transform": [
        {
          "filter": "datum.year == selected_year"
        },
        {
          "aggregate": [
            {
              "op": "sum",
              "field": "cell_count",
              "as": "total_fire_cells"
            }
          ],
          "groupby": ["state", "year", "latitude", "longitude"]
        }
      ],
      "mark": {
        "type": "text",
        "fontSize": 12,
        "fontWeight": "bold",
        "dy": -12,
        "color": "#1F1F1F"
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "text": {
          "field": "state",
          "type": "nominal"
        }
      }
    },

    {
      "data": {
        "values": [
          {
            "longitude": 134,
            "latitude": -45,
            "label": "X-axis: Longitude"
          }
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 13,
        "fontWeight": "bold",
        "color": "#333333"
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    },

    {
      "data": {
        "values": [
          {
            "longitude": 111,
            "latitude": -28,
            "label": "Y-axis: Latitude"
          }
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 13,
        "fontWeight": "bold",
        "angle": 270,
        "color": "#333333"
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    }
  ],

  "resolve": {
    "scale": {
      "color": "independent",
      "size": "independent"
    }
  },

  "config": {
    "view": {
      "stroke": null
    },
    "legend": {
      "labelFont": "Arial",
      "titleFont": "Arial"
    },
    "title": {
      "font": "Arial",
      "subtitleFont": "Arial"
    }
  }
}