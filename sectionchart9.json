{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Vertical lollipop chart showing conservation actions ranked by number of species benefiting.",
  "width": 650,
  "height": 420,
  "background": "#FAF8F3",
  "title": {
    "text": "Conservation Actions Ranked by Number of Species Benefiting",
    "subtitle": "Higher values indicate conservation actions that benefit more species",
    "anchor": "middle",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "color": "#2F3A2F",
    "subtitleColor": "#5E6B5E",
    "subtitlePadding": 10
  },
  "data": {
    "url": "bio_095_barchart.csv"
  },
  "transform": [
    {
      "calculate": "0",
      "as": "Start"
    },
    {
      "calculate": "toNumber(datum.Number)",
      "as": "Species_Benefiting"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeWidth": 3
      },
      "encoding": {
        "x": {
          "field": "Category",
          "type": "nominal",
          "sort": {
            "field": "Species_Benefiting",
            "order": "descending"
          },
          "axis": {
            "title": "Conservation Action",
            "labelAngle": -30,
            "labelFontSize": 11,
            "titleFontSize": 13,
            "labelLimit": 160
          }
        },
        "y": {
          "field": "Start",
          "type": "quantitative",
          "axis": {
            "title": "Number of Species Benefiting",
            "labelFontSize": 12,
            "titleFontSize": 13,
            "titlePadding": 15,
            "grid": true
          },
          "scale": {
            "zero": true,
            "nice": true
          }
        },
        "y2": {
          "field": "Species_Benefiting"
        },
        "color": {
          "field": "Category",
          "type": "nominal",
          "scale": {
            "scheme": "tableau10"
          },
          "legend": {
            "title": "Conservation Action",
            "orient": "right",
            "labelFontSize": 11,
            "titleFontSize": 12
          }
        },
        "tooltip": [
          {
            "field": "Category",
            "type": "nominal",
            "title": "Conservation Action"
          },
          {
            "field": "Species_Benefiting",
            "type": "quantitative",
            "title": "Species Benefiting"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "circle",
        "size": 300,
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "field": "Category",
          "type": "nominal",
          "sort": {
            "field": "Species_Benefiting",
            "order": "descending"
          }
        },
        "y": {
          "field": "Species_Benefiting",
          "type": "quantitative"
        },
        "color": {
          "field": "Category",
          "type": "nominal",
          "scale": {
            "scheme": "tableau10"
          },
          "legend": null
        },
        "tooltip": [
          {
            "field": "Category",
            "type": "nominal",
            "title": "Conservation Action"
          },
          {
            "field": "Species_Benefiting",
            "type": "quantitative",
            "title": "Species Benefiting"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "dy": -12,
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#333333"
      },
      "encoding": {
        "x": {
          "field": "Category",
          "type": "nominal",
          "sort": {
            "field": "Species_Benefiting",
            "order": "descending"
          }
        },
        "y": {
          "field": "Species_Benefiting",
          "type": "quantitative"
        },
        "text": {
          "field": "Species_Benefiting",
          "type": "quantitative"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#333333",
      "titleColor": "#333333",
      "gridColor": "#DDD8C8",
      "domainColor": "#999999",
      "tickColor": "#999999"
    },
    "legend": {
      "labelColor": "#333333",
      "titleColor": "#333333"
    }
  }
}